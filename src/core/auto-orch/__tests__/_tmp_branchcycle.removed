import { describe, it, expect } from 'vitest'
import { PlanRunner, type NodeRunner } from '../PlanRunner.js'
import type { OrchPlan } from '../LoopIR.js'
import { validatePlan } from '../LoopIR.js'
import type { OrchVerdict } from '../Verdict.js'

// Workflow: A → B ; B ok → C ; B error → D ; C → A (cycle)
const plan: OrchPlan = {
  entry: 'A',
  nodes: [
    { id: 'A', kind: 'executor', taskDescription: 'A' },
    { id: 'B', kind: 'executor', taskDescription: 'B' },
    { id: 'C', kind: 'executor', taskDescription: 'C' },
    { id: 'D', kind: 'executor', taskDescription: 'D' },
  ],
  edges: [
    { from: 'A', to: 'B' },                                              // always
    { from: 'B', to: 'C', when: { on: 'verdictLabel', label: 'ok' } },   // B correct → C
    { from: 'B', to: 'D', when: { on: 'verdictLabel', label: 'error' } },// B error → D
    { from: 'C', to: 'A', when: { on: 'verdictLabel', label: 'loop' } }, // C → A (cycle)
    // C with label 'done' has NO matching edge → terminal
  ],
  bounds: { maxNodeVisits: 5 },
}

describe('branch + cycle workflow', () => {
  it('validates', () => {
    expect(validatePlan(plan)).toHaveLength(0)
  })

  it('B error → D path', async () => {
    const runner: NodeRunner = {
      async run(node): Promise<OrchVerdict> {
        if (node.id === 'B') return { action: 'branch', label: 'error' }
        return { action: 'branch', label: 'ok' }
      },
    }
    const r = await new PlanRunner(plan, runner).run(new AbortController().signal)
    expect(r.visitedPath).toEqual(['A', 'B', 'D'])
  })

  it('B ok → C → A → B ... cycle, then C terminates', async () => {
    let cVisits = 0
    const runner: NodeRunner = {
      async run(node): Promise<OrchVerdict> {
        if (node.id === 'C') {
          cVisits++
          // first time loop back to A; second time finish (no matching edge)
          return cVisits < 2 ? { action: 'branch', label: 'loop' } : { action: 'done', label: 'done' }
        }
        return { action: 'branch', label: 'ok' } // A and B succeed
      },
    }
    const r = await new PlanRunner(plan, runner).run(new AbortController().signal)
    expect(r.status).toBe('completed')
    expect(r.visitedPath).toEqual(['A', 'B', 'C', 'A', 'B', 'C'])
  })
})
