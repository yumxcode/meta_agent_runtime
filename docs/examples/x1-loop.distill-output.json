{
  "graph": {
    "schemaVersion": "graph-1.0",
    "id": "x1-humanoid-walking-research",
    "version": 1,
    "goal": "围绕 task_spec.md 持续推进人形机器人行走控制研究，以可验证证据迭代方向；健康进展时继续，连续停滞时进行结构性 pivot，达到成功标准、需要人工关注或发生不可恢复错误时优雅停止。",
    "state": {
      "iteration": {
        "type": { "type": "integer", "minimum": 0 },
        "initial": 0,
        "description": "已完成并提交的研究迭代数。"
      },
      "stale_count": {
        "type": { "type": "integer", "minimum": 0 },
        "initial": 0,
        "description": "连续无新增 finding 或结果变差的迭代数。"
      },
      "total_findings": {
        "type": { "type": "integer", "minimum": 0 },
        "initial": 0,
        "description": "Agent 声明并经本轮语义评价确认的新增 finding 数量累计。"
      },
      "status": {
        "type": {
          "type": "string",
          "enum": ["healthy", "stale", "pivot_required", "attention_required", "error", "completed"]
        },
        "initial": "healthy",
        "description": "Kernel 权威控制状态。"
      },
      "updated_at": {
        "type": { "type": "number", "minimum": 0 },
        "initial": 0,
        "description": "最近一次路由提交时间（Unix epoch ms）。"
      }
    },
    "lanes": {
      "research": {
        "context": "persistent",
        "workspace": "shared_controlled",
        "maxConcurrency": 1,
        "description": "贯穿方向选择、设计实现、远端训练观察、finding 提取和 structural pivot 的长期研究上下文与单写工作副本；状态投影由 Kernel 维护。",
        "agentProfile": {
          "systemInstructions": "持续维护该长期研究生命周期的认知连续性；区分实验事实、推断和待验证假设，并以 Kernel State 和带 provenance 的 Evidence 为控制事实。"
        },
        "dataAccess": {
          "read": [
            { "plane": "control", "views": ["control_full", "control_cycle", "control_pivot", "control_error"] },
            { "plane": "task_definition", "views": ["task_spec"] },
            { "plane": "research_history", "views": ["research_history"] },
            { "plane": "directions", "views": ["direction_history"] }
          ],
          "publish": ["research_history", "accepted_findings", "directions", "reports"],
          "write": ["work_log"]
        },
        "workspaceAccess": {
          "write": ["humanoid", ".oma/experiments", "logs/work.jsonl", "state/attention_required.md", "state/error_report.md"],
          "deny": ["state/progress.json", "state/findings.jsonl", "state/directions_tried.json", "state/iteration_log.jsonl", "logs/orchestrator.jsonl"]
        }
      }
    },
    "nodes": {
      "research_cycle": {
        "type": "agent",
        "lane": "research",
        "description": "一个完整研究迭代；远端训练的提交、观察和收口属于同一个可 hard-park 的 Agent Activation。",
        "prompt": "执行一个完整的人形机器人行走控制研究迭代。依据注入的 task specification、Kernel State、研究 Evidence 和 continuation checkpoint，选择一个与历史实质不同、能推进成功标准的方向。完成必要调研、设计、实现并通过用户预先配置的 bash/Skill 操作远端 Gradmotion 训练。Gradmotion 任务未结束时不要退出本 Activation：记录 job id、step 和判断依据，调用 timer hard park，通常 30 分钟后在同一 Activation/Lane 恢复；若指标进入平台期且没有明显改善倾向，及时终止远端训练并收口。遇到账号无余额时，按用户提供的 account-pool CLI 先 remove 当前 id，再 get 新账号，随后继续同一研究生命周期；Kernel 不提供账号资源锁。训练结束后提取有证据的结构化 findings，判断是否确有新增发现、结果趋势、成功标准是否已达到、是否发生领域错误。可以写工作过程日志，但不要手工写 progress/findings/directions/iteration_log；Kernel 将依据结构化输出完成路由、Evidence/Artifact publication 和 workspace projection。",
        "context": {
          "sections": [
            { "name": "task_spec", "provider": "builtin/data-plane-view@1", "refresh": "activation_start", "config": { "view": "task_spec" }, "maxBytes": 65536 },
            { "name": "control_state", "provider": "builtin/data-plane-view@1", "refresh": "every_segment", "config": { "view": "control_full" }, "maxBytes": 4096 },
            { "name": "research_history", "provider": "builtin/data-plane-view@1", "refresh": "activation_start", "config": { "view": "research_history" }, "maxBytes": 65536 },
            { "name": "resume_checkpoint", "provider": "builtin/continuation@1", "refresh": "continuation_only", "maxBytes": 4096 }
          ]
        },
        "tools": ["read_file", "edit_file", "write_file", "grep", "glob", "bash"],
        "reads": ["humanoid", ".oma"],
        "writes": ["humanoid", ".oma/experiments", "logs/work.jsonl"],
        "maxAttempts": 3,
        "budget": {
          "turns": 40,
          "usd": 4,
          "wallTimeMs": 1200000
        },
        "lifetimeBudget": {
          "turns": 800,
          "usd": 60,
          "elapsedMs": 259200000
        },
        "timerPolicy": {
          "allowHardPark": true,
          "maxDelayMs": 3600000,
          "maxParks": 144
        },
        "outputSchema": {
          "type": "object",
          "required": [
            "direction",
            "summary",
            "new_findings_count",
            "result_trend",
            "goal_complete",
            "cycle_error",
            "findings"
          ],
          "properties": {
            "direction": { "type": "string", "minLength": 1 },
            "summary": { "type": "string", "minLength": 1 },
            "new_findings_count": { "type": "integer", "minimum": 0 },
            "result_trend": { "type": "string", "enum": ["improved", "unchanged", "regressed"] },
            "goal_complete": { "type": "boolean" },
            "cycle_error": { "type": "boolean" },
            "remote_job_id": { "type": "string" },
            "findings": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["claim", "evidence", "confidence"],
                "properties": {
                  "claim": { "type": "string", "minLength": 1 },
                  "evidence": { "type": "string", "minLength": 1 },
                  "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        },
        "publishes": [
          {
            "plane": "research_history",
            "value": { "ref": "$output" },
            "status": "admitted",
            "tags": ["x1", "walking-control", "research-cycle"]
          },
          {
            "plane": "accepted_findings",
            "value": { "ref": "$output.findings" },
            "status": "admitted",
            "tags": ["x1", "finding"]
          },
          {
            "plane": "directions",
            "value": { "ref": "$output.direction" },
            "status": "admitted",
            "tags": ["x1", "direction"]
          }
        ]
      },
      "structural_pivot": {
        "type": "agent",
        "lane": "research",
        "description": "停滞后的结构性研究框架调整，而非参数微调。",
        "prompt": "执行 structural pivot。依据 task specification、现有 findings/evidence 和方向历史，先调研高置信度前沿论文与相关进展，然后至少从以下一种结构层面改变约束：相反假设、不同数据源或证据类型、跨领域结构相似案例、不同评估指标、不同环境假设或不同控制框架。不得只调超参数。输出新方向、理由和来源；Kernel 会 publication 并物化方向历史和迭代审计。不要修改 Kernel 的 stale_count 或自行选择下一节点。",
        "systemInstructions": "当前节点执行结构性方向调整；不得把普通参数微调表述为结构性变化。",
        "context": {
          "sections": [
            { "name": "task_spec", "provider": "builtin/data-plane-view@1", "refresh": "activation_start", "config": { "view": "task_spec" }, "maxBytes": 65536 },
            { "name": "control_state", "provider": "builtin/data-plane-view@1", "refresh": "every_segment", "config": { "view": "control_pivot" }, "maxBytes": 4096 },
            { "name": "research_history", "provider": "builtin/data-plane-view@1", "refresh": "activation_start", "config": { "view": "research_history" }, "maxBytes": 65536 },
            { "name": "direction_history", "provider": "builtin/data-plane-view@1", "refresh": "activation_start", "config": { "view": "direction_history" }, "maxBytes": 32768 }
          ]
        },
        "tools": ["read_file", "edit_file", "write_file", "grep", "glob", "bash"],
        "reads": ["humanoid", ".oma"],
        "writes": ["logs/work.jsonl"],
        "maxAttempts": 3,
        "budget": {
          "turns": 30,
          "usd": 3,
          "wallTimeMs": 1800000
        },
        "outputSchema": {
          "type": "object",
          "required": ["direction", "rationale", "sources"],
          "properties": {
            "direction": { "type": "string", "minLength": 1 },
            "rationale": { "type": "string", "minLength": 1 },
            "sources": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        },
        "publishes": [
          {
            "plane": "research_history",
            "value": { "ref": "$output" },
            "status": "admitted",
            "tags": ["x1", "structural-pivot"]
          },
          {
            "plane": "directions",
            "value": { "ref": "$output.direction" },
            "status": "admitted",
            "tags": ["x1", "direction", "structural-pivot"]
          }
        ]
      },
      "write_attention_report": {
        "type": "agent",
        "lane": "research",
        "description": "写 attention_required 报告后自动停止，不向用户提问。",
        "prompt": "根据 task specification、Kernel State、方向历史和公共 Evidence 写出 state/attention_required.md。说明连续停滞证据、已尝试的结构性 pivot、当前远端任务状态、保留的工作副本与建议的人工检查点。progress 和 iteration audit 由 Kernel projection 维护。不要向用户提问；完成报告后返回路径和摘要。",
        "context": {
          "sections": [
            { "name": "task_spec", "provider": "builtin/data-plane-view@1", "refresh": "activation_start", "config": { "view": "task_spec" }, "maxBytes": 65536 },
            { "name": "control_state", "provider": "builtin/data-plane-view@1", "refresh": "activation_start", "config": { "view": "control_cycle" }, "maxBytes": 4096 },
            { "name": "research_history", "provider": "builtin/data-plane-view@1", "refresh": "activation_start", "config": { "view": "research_history" }, "maxBytes": 65536 },
            { "name": "direction_history", "provider": "builtin/data-plane-view@1", "refresh": "activation_start", "config": { "view": "direction_history" }, "maxBytes": 32768 }
          ]
        },
        "tools": ["read_file", "edit_file", "write_file", "grep", "glob"],
        "writes": ["state/attention_required.md"],
        "maxAttempts": 2,
        "budget": {
          "turns": 16,
          "usd": 1,
          "wallTimeMs": 600000
        },
        "outputSchema": {
          "type": "object",
          "required": ["report_path", "summary"],
          "properties": {
            "report_path": { "type": "string", "minLength": 1 },
            "summary": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "publishes": [
          {
            "plane": "reports",
            "value": { "ref": "$output" },
            "status": "admitted",
            "tags": ["x1", "attention-required"]
          }
        ]
      },
      "write_error_report": {
        "type": "agent",
        "lane": "research",
        "description": "持久化错误状态和错误迭代日志后终止。",
        "prompt": "把输入中的错误原因、最近研究上下文、远端任务状态和可恢复线索写入 state/error_report.md。Kernel 已负责 error State 和 iteration audit projection；不要手工双写这些投影。不要继续训练或向用户提问。返回报告路径和摘要。",
        "context": {
          "sections": [
            { "name": "control_state", "provider": "builtin/data-plane-view@1", "refresh": "activation_start", "config": { "view": "control_error" }, "maxBytes": 4096 },
            { "name": "activation_input", "provider": "builtin/input@1", "refresh": "activation_start", "maxBytes": 8192 },
            { "name": "research_history", "provider": "builtin/data-plane-view@1", "refresh": "activation_start", "config": { "view": "research_history" }, "maxBytes": 65536 }
          ]
        },
        "tools": ["read_file", "edit_file", "write_file", "grep", "glob", "bash"],
        "writes": ["state/error_report.md"],
        "maxAttempts": 2,
        "budget": {
          "turns": 16,
          "usd": 1,
          "wallTimeMs": 600000
        },
        "outputSchema": {
          "type": "object",
          "required": ["report_path", "summary"],
          "properties": {
            "report_path": { "type": "string", "minLength": 1 },
            "summary": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "publishes": [
          {
            "plane": "reports",
            "value": { "ref": "$output" },
            "status": "admitted",
            "tags": ["x1", "error"]
          }
        ]
      },
      "done": {
        "type": "terminal",
        "status": "done",
        "result": { "ref": "$input.result" }
      },
      "attention_stopped": {
        "type": "terminal",
        "status": "done",
        "result": { "ref": "$input.result" }
      },
      "failed": {
        "type": "terminal",
        "status": "failed",
        "result": { "ref": "$input.result" }
      }
    },
    "transitions": [
      {
        "id": "cycle-error",
        "from": "research_cycle",
        "when": "$output.cycle_error == true",
        "priority": 100,
        "updates": [
          { "target": "status", "reducer": "builtin/set@1", "args": [{ "literal": "error" }] },
          { "target": "updated_at", "reducer": "builtin/set@1", "args": [{ "ref": "$clock.now" }] }
        ],
        "to": {
          "node": "write_error_report",
          "inputs": { "cause": { "ref": "$output" } }
        }
      },
      {
        "id": "goal-complete",
        "from": "research_cycle",
        "when": "$output.goal_complete == true",
        "priority": 90,
        "updates": [
          { "target": "iteration", "reducer": "builtin/increment@1" },
          { "target": "total_findings", "reducer": "builtin/add@1", "args": [{ "ref": "$output.new_findings_count" }] },
          { "target": "stale_count", "reducer": "builtin/set@1", "args": [{ "literal": 0 }] },
          { "target": "status", "reducer": "builtin/set@1", "args": [{ "literal": "completed" }] },
          { "target": "updated_at", "reducer": "builtin/set@1", "args": [{ "ref": "$clock.now" }] }
        ],
        "to": {
          "node": "done",
          "inputs": { "result": { "ref": "$output" } }
        }
      },
      {
        "id": "attention-after-fourth-stale",
        "from": "research_cycle",
        "when": "($output.new_findings_count == 0 || $output.result_trend == \"regressed\") && $state.stale_count >= 3",
        "priority": 80,
        "updates": [
          { "target": "iteration", "reducer": "builtin/increment@1" },
          { "target": "total_findings", "reducer": "builtin/add@1", "args": [{ "ref": "$output.new_findings_count" }] },
          { "target": "stale_count", "reducer": "builtin/increment@1" },
          { "target": "status", "reducer": "builtin/set@1", "args": [{ "literal": "attention_required" }] },
          { "target": "updated_at", "reducer": "builtin/set@1", "args": [{ "ref": "$clock.now" }] }
        ],
        "to": "write_attention_report"
      },
      {
        "id": "pivot-after-second-stale",
        "from": "research_cycle",
        "when": "($output.new_findings_count == 0 || $output.result_trend == \"regressed\") && $state.stale_count >= 1",
        "priority": 70,
        "updates": [
          { "target": "iteration", "reducer": "builtin/increment@1" },
          { "target": "total_findings", "reducer": "builtin/add@1", "args": [{ "ref": "$output.new_findings_count" }] },
          { "target": "stale_count", "reducer": "builtin/increment@1" },
          { "target": "status", "reducer": "builtin/set@1", "args": [{ "literal": "pivot_required" }] },
          { "target": "updated_at", "reducer": "builtin/set@1", "args": [{ "ref": "$clock.now" }] }
        ],
        "to": "structural_pivot"
      },
      {
        "id": "first-stale",
        "from": "research_cycle",
        "when": "$output.new_findings_count == 0 || $output.result_trend == \"regressed\"",
        "priority": 60,
        "updates": [
          { "target": "iteration", "reducer": "builtin/increment@1" },
          { "target": "total_findings", "reducer": "builtin/add@1", "args": [{ "ref": "$output.new_findings_count" }] },
          { "target": "stale_count", "reducer": "builtin/increment@1" },
          { "target": "status", "reducer": "builtin/set@1", "args": [{ "literal": "stale" }] },
          { "target": "updated_at", "reducer": "builtin/set@1", "args": [{ "ref": "$clock.now" }] }
        ],
        "to": "research_cycle"
      },
      {
        "id": "healthy-progress",
        "from": "research_cycle",
        "default": true,
        "updates": [
          { "target": "iteration", "reducer": "builtin/increment@1" },
          { "target": "total_findings", "reducer": "builtin/add@1", "args": [{ "ref": "$output.new_findings_count" }] },
          { "target": "stale_count", "reducer": "builtin/set@1", "args": [{ "literal": 0 }] },
          { "target": "status", "reducer": "builtin/set@1", "args": [{ "literal": "healthy" }] },
          { "target": "updated_at", "reducer": "builtin/set@1", "args": [{ "ref": "$clock.now" }] }
        ],
        "to": "research_cycle"
      },
      {
        "id": "cycle-execution-failed",
        "from": "research_cycle",
        "on": "failure",
        "updates": [
          { "target": "status", "reducer": "builtin/set@1", "args": [{ "literal": "error" }] },
          { "target": "updated_at", "reducer": "builtin/set@1", "args": [{ "ref": "$clock.now" }] }
        ],
        "to": {
          "node": "write_error_report",
          "inputs": { "cause": { "ref": "$output" } }
        }
      },
      {
        "id": "pivot-finished",
        "from": "structural_pivot",
        "updates": [
          { "target": "status", "reducer": "builtin/set@1", "args": [{ "literal": "healthy" }] },
          { "target": "updated_at", "reducer": "builtin/set@1", "args": [{ "ref": "$clock.now" }] }
        ],
        "to": "research_cycle"
      },
      {
        "id": "pivot-failed",
        "from": "structural_pivot",
        "on": "failure",
        "updates": [
          { "target": "status", "reducer": "builtin/set@1", "args": [{ "literal": "error" }] },
          { "target": "updated_at", "reducer": "builtin/set@1", "args": [{ "ref": "$clock.now" }] }
        ],
        "to": {
          "node": "write_error_report",
          "inputs": { "cause": { "ref": "$output" } }
        }
      },
      {
        "id": "attention-report-written",
        "from": "write_attention_report",
        "to": {
          "node": "attention_stopped",
          "inputs": { "result": { "ref": "$output" } }
        }
      },
      {
        "id": "attention-report-failed",
        "from": "write_attention_report",
        "on": "failure",
        "to": {
          "node": "failed",
          "inputs": { "result": { "ref": "$output" } }
        }
      },
      {
        "id": "error-report-written",
        "from": "write_error_report",
        "to": {
          "node": "failed",
          "inputs": { "result": { "ref": "$output" } }
        }
      },
      {
        "id": "error-report-failed",
        "from": "write_error_report",
        "on": "failure",
        "to": {
          "node": "failed",
          "inputs": { "result": { "ref": "$output" } }
        }
      }
    ],
    "entrypoints": [
      {
        "id": "start",
        "node": "research_cycle"
      }
    ],
    "dataPlanes": {
      "control": {
        "backend": "state",
        "semanticRole": "确定性研究循环控制事实",
        "trust": "trusted_runtime",
        "stateKeys": ["iteration", "stale_count", "total_findings", "status", "updated_at"]
      },
      "task_definition": {
        "backend": "workspace",
        "semanticRole": "用户权威任务目标与成功标准",
        "trust": "untrusted_data",
        "binding": {
          "plane": "input",
          "path": "state/task_spec.md",
          "format": "markdown",
          "direction": "ingest",
          "lane": "research",
          "required": true
        }
      },
      "research_history": {
        "backend": "record",
        "semanticRole": "研究轮次与结构转向产生的判断依据",
        "trust": "untrusted_data",
        "recordKind": "evidence",
        "mutability": "append_only",
        "admission": "automatic",
        "retention": { "maxItems": 160 }
      },
      "accepted_findings": {
        "backend": "record",
        "semanticRole": "经本轮语义评价接受的新增发现",
        "trust": "untrusted_data",
        "recordKind": "evidence",
        "mutability": "append_only",
        "admission": "automatic",
        "retention": { "maxItems": 512 }
      },
      "directions": {
        "backend": "record",
        "semanticRole": "已尝试研究方向",
        "trust": "untrusted_data",
        "recordKind": "artifact",
        "mutability": "append_only",
        "admission": "automatic",
        "retention": { "maxItems": 256 }
      },
      "reports": {
        "backend": "record",
        "semanticRole": "需要关注或失败时的收口报告",
        "trust": "untrusted_data",
        "recordKind": "artifact",
        "mutability": "append_only",
        "admission": "automatic",
        "retention": { "maxItems": 16 }
      },
      "runtime_audit": {
        "backend": "journal",
        "semanticRole": "Kernel 因果与调度审计",
        "trust": "untrusted_data",
